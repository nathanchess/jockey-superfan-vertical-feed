# TwelveLabs API (required for search, playback, and Jockey spotlight)
TL_API_KEY=

# Marengo index — semantic search + HLS playback resolution
TL_INDEX_ID=

# Jockey knowledge store — cross-episode spotlight queries (optional but recommended)
TL_KS_ID=

# Override API base (default: https://api.twelvelabs.io/v1.3)
# TWELVELABS_API_BASE=https://api.twelvelabs.io/v1.3
