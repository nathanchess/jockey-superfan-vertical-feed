# TwelveLabs API (required for all shows — search, playback, Jockey spotlight)
TL_API_KEY=

# ── Per-show Jockey Knowledge Store IDs ──────────────────────────────────────
# Populated by running: python pre-processing/knowledge_store.py <show>
# Index IDs are hardcoded in app/lib/shows.ts (not secrets).

TL_KS_ID_KN=           # Kitchen Nightmares KS — set after running knowledge_store.py kn
TL_KS_ID_TIWBG=        # The Island with Bear Grylls KS — set after running knowledge_store.py tiwbg
TL_KS_ID_RHOSLC=ks_06a14df8-c166-724b-8000-57960b9d6bcb

# ── Password protection ───────────────────────────────────────────────────────
# Server-side only; never sent to the browser.
RHOSLC_PASSWORD=        # Set any password to unlock The Real Housewives in the UI

# ── Legacy fallbacks (no longer required when per-show vars are set) ──────────
# TL_INDEX_ID=
# TL_KS_ID=

# Override API base (default: https://api.twelvelabs.io/v1.3)
# TWELVELABS_API_BASE=https://api.twelvelabs.io/v1.3
